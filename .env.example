# =============================================================================
# DROPKAST environment variables
# Copy to .env (never commit). Each section says where to obtain the key.
# Variables prefixed with VITE_ are exposed to the browser bundle — only put
# *public* keys there. All other vars are server-only.
# =============================================================================

# --- Anthropic (Claude) — primary AI provider ---
# Powers the AI assistant, A&R critique, campaign strategy, viral ideas.
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Free chat-model providers (OpenAI-compatible) ---
# Any of these unlock free fallback chat in the assistant. Add keys for
# whichever you want available in the model picker.
# NVIDIA NIM:  https://build.nvidia.com   (40 RPM free, indefinite)
# Groq:        https://console.groq.com   (1M tokens/day free)
# Cerebras:    https://cloud.cerebras.ai  (1M tokens/day free, 8K ctx)
# OpenRouter:  https://openrouter.ai/keys (free models for many vendors)
NVIDIA_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=

# --- Image / video generation (optional, for Phase 2 model picker) ---
# Adapters are stubbed; see /ai-providers in the app for current pricing.
GOOGLE_API_KEY=        # Nano Banana / Veo via AI Studio
FAL_API_KEY=           # Flux Schnell/Dev/Pro, Seedance via fal.ai
OPENAI_API_KEY=        # DALL-E 3 / gpt-image-1 / Sora
KLING_API_KEY=         # Kling video
RUNWAY_API_KEY=        # Runway Gen-4
LUMA_API_KEY=          # Luma Dream Machine
PIKA_API_KEY=          # Pika Labs
HAILUO_API_KEY=        # MiniMax Hailuo
IDEOGRAM_API_KEY=      # Ideogram (text-in-image)

# --- Database (Postgres via Supabase or Neon) ---
# Connection string for Drizzle ORM. Falls back to in-memory if missing.
# Supabase: Project Settings → Database → Connection String → URI (use the
# pooled connection for serverless).
# Neon: Connection Details → Pooled connection.
DATABASE_URL=

# --- Supabase Auth (client) ---
# Public, safe to expose. Used by the browser to authenticate users.
# Project Settings → API → Project URL and anon/public key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Supabase service role (server only) ---
# Used by API routes for privileged operations (admin tasks, RLS bypass).
# NEVER expose this to the client. Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudinary (audio + artwork uploads) ---
# Get keys at https://cloudinary.com/console — the demo falls back to in-memory
# upload storage if these are missing.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Stripe (Phase 3 — splits payouts) ---
# Test keys for development; switch to live keys in production.
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- DSP delivery (Phase 1 — RouteNote, optional) ---
# Set up at https://routenote.com/distribution-partners (B2B partner program).
ROUTENOTE_API_KEY=

# --- Sentry (Phase 6) ---
# https://sentry.io → Project Settings → Client Keys (DSN)
SENTRY_DSN=
VITE_SENTRY_DSN=

# --- Developer bypass mode (for when Supabase is not configured) ---
# When VITE_AUTH_BYPASS=true and Supabase is not configured, these
# credentials let you sign in with full admin access to all portals.
# Set DEV_MODE=true and ADMIN_EMAILS on the server side so the backend
# accepts the bypass headers.
VITE_AUTH_BYPASS=true
VITE_BYPASS_EMAIL=admin@dropkast.dev
VITE_BYPASS_PASSWORD=dropkast123
VITE_BYPASS_USER_ID=dev-user-001
VITE_BYPASS_NAME=Dev Admin
DEV_MODE=true
ADMIN_EMAILS=admin@dropkast.dev

# --- Local dev only ---
# Override the dev server port (default 4002).
PORT=4002
