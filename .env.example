# =============================================================================
# DROPKAST environment variables
# Copy to .env (never commit). Each section says where to obtain the key.
# Variables prefixed with VITE_ are exposed to the browser bundle — only put
# *public* keys there. All other vars are server-only.
# =============================================================================

# --- Anthropic (Claude) ---
# Powers the AI assistant, A&R critique, campaign strategy, viral ideas.
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Database (Postgres via Supabase or Neon) ---
# Connection string for Drizzle ORM. Falls back to in-memory if missing.
# Supabase: Project Settings → Database → Connection String → URI (use the
# pooled connection for serverless).
# Neon: Connection Details → Pooled connection.
DATABASE_URL=

# --- Supabase Auth (client) ---
# Public, safe to expose. Used by the browser to authenticate users.
# Project Settings → API → Project URL and anon/public key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Supabase service role (server only) ---
# Used by API routes for privileged operations (admin tasks, RLS bypass).
# NEVER expose this to the client. Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudinary (audio + artwork uploads) ---
# Get keys at https://cloudinary.com/console — the demo falls back to in-memory
# upload storage if these are missing.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Stripe (Phase 3 — splits payouts) ---
# Test keys for development; switch to live keys in production.
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- DSP delivery (Phase 1 — RouteNote, optional) ---
# Set up at https://routenote.com/distribution-partners (B2B partner program).
ROUTENOTE_API_KEY=

# --- Sentry (Phase 6) ---
# https://sentry.io → Project Settings → Client Keys (DSN)
SENTRY_DSN=
VITE_SENTRY_DSN=

# --- Local dev only ---
# Override the dev server port (default 4002).
PORT=4002
